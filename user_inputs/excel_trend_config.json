{
  "description": "Configure which columns from Excel data files to extract and trend across serial numbers.",
  "data_group": "Excel Data",
  "columns": [
    { "name": "thrust", "units": "lbf", "range_min": null, "range_max": null },
    { "name": "isp", "units": "s", "range_min": null, "range_max": null },
    { "name": "pc", "units": "psia", "range_min": null, "range_max": null }
  ],
  "statistics": ["mean", "min", "max", "std"],
  "statistics_ignore_first_n": 0,
  "performance_plotters": [
    {
      "name": "Standard Thrust Equation",
      "x": { "column": "isp" },
      "y": { "column": "thrust" },
      "stats": ["mean", "min", "max"],
      "fit": { "degree": 2, "normalize_x": true },
      "require_min_points": 2
    }
  ],
  "sheet_name": null,
  "header_row": 0,
  "td_run_labeling": {
    "enabled": false,
    "template": "{pressure}psia, {run_type}, {pulse_on}ON/{pulse_off}OFF",
    "missing_value": "blank",
    "value_pick": "most_common",
    "duplicate_disambiguation": {
      "enabled": true,
      "template": "{label} — {run_name}"
    },
    "fuzzy_match": {
      "enabled": true,
      "min_ratio": 0.82
    },
    "variables": {
      "pressure": { "column": "pressure", "format": ".0f" },
      "run_type": { "column": "run type" },
      "pulse_on": { "column": "pulse on", "format": ".0f" },
      "pulse_off": { "column": "pulse off", "format": ".0f" }
    }
  },
  "x_axis": {
    "replace_defaults": false,
    "time_aliases": ["Seq Time (sec)", "Seq Time (s)", "Time (sec)", "Time(s)", "Time (s)", "time_s", "time_sec", "time"],
    "pulse_aliases": ["Pulse Number", "Pulse #", "Pulse", "cycle", "Cycle", "pulse_number", "pulsenumber"],
    "fuzzy_match": { "enabled": true, "min_ratio": 0.82 },
    "sequential_validation": { "enabled": true, "max_probe_rows": 250, "min_samples": 6, "pulse_min_run": 5 },
    "fallback_mode": "alias_only",
    "default_x": "Time"
  }
}
